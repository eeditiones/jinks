{
    "singleQuote": false,
    "semi": true,
    "useTabs": false,
    "tabWidth": 4,
    "printWidth": 100,
    "plugins": ["prettier-plugin-xquery", "prettier-plugin-jinks"],
    "overrides": [
        {
            "files": ["*.tpl.*", "*.tps.*", "*.html"],
            "options": {
                "parser": "jinks-templating"
            }
        }
    ]
}
