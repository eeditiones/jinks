{
    "$schema": "../../schema/jinks.json",
    "type": "feature",
    "category": "development",
    "id": "https://e-editiones.org/app/tei-publisher/sitemap",
    "label": "Sitemap + SEO",
    "description": "Adds an action to generate a sitemap and adds canonical urls to all pages",
    "version": "1.0.0",
    "depends": [
        "base10"
    ],
    "skipSource": [
        "tools/.*"
    ],
    "api": [
        {
            "spec": "sitemap-api.json",
            "prefix": "sitemap",
            "path": "sitemap.xql",
            "id": "http://tei-publisher.org/api/sitemap"
        }
    ],
    "actions": [
        {
            "name": "sitemap",
            "label": "Sitemap",
            "description": "Generate a sitemap.xml containing all document URLs and their pages"
        }
    ],
	"templating": {
		"use": [
			"templates/seo-blocks.html"
		]
	},
    "features": {
        "sitemap": {
            "custom": [
                "index.html"
            ]
        }
    }
}
