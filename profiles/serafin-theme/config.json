{
    "$schema": "../../schema/jinks.json",
    "type": "theme",
    "id": "https://e-editiones.org/app/tei-publisher/serafin-theme",
    "label": "Serafin theme",
    "description": "Parchment-and-ink styling, flat rectangular controls, extending the default Jinks theme",
    "order": 2,
    "version": "1.0.0",
    "depends": [
        "base10",
        "theme-base10"
    ],
    "theme": {
        "fonts": {
            "base": {
                "family": "'Albert Sans', sans-serif"
            },
            "content": {
                "family": "'Albert Sans', sans-serif",
                "size": "1.2rem"
            },
            "heading": {
                "family": "'Belleza', sans-serif",
                "weight": "400"
            }
        },
        "content": {
            "max-width": "48ch"
        },
        "breadcrumbs": {
            "max": "none"
        },
        "texture": {
            "background-image": "../images/parchment.png"
        },
        "colors": {
            "palette": "beige"
        },
        "components": {
            "styles": "resources/css/serafin-theme-components.css"
        }
    },
    "styles": [
        "resources/css/serafin-theme.css"
    ]
}
