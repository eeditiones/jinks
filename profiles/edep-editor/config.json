{
    "$schema": "../../schema/jinks.json",
    "label": "EDEp - Epidoc Editor",
    "description": "Provides a form-based editor for Epidoc documents.",
    "id": "https://e-editiones.org/profiles/edep-editor",
    "type": "feature",
    "category": "components",
    "version": "1.0.0",
    "depends": [
        "base10",
        "upload",
        "forms"
    ],
    "odds": [
        "edep-clean.odd",
        "edep.odd"
    ],
    "defaults": {
        "odd": "edep.odd",
        "data-default": "workspace"
    },
    "theme": {
        "icons": [ "edep-icons.svg" ]
    },
    "templating": {
        "use": [
            "templates/edep-blocks.html"
        ]
    },
    "api": [
        {
            "spec": "edep-api.json",
            "prefix": "edep",
            "path": "edep-api.xql",
            "id": "http://e-editiones.org/api/edep"
        },
        {
            "prefix": "zotero",
            "path": "zotero.xql",
            "id": "http://e-editiones.org/edep/api/zotero"
        }
    ],
    "features": {
        "edep": {
            "toolbar-button": true
        },
        "zotero": {
            "api_base": "https://api.zotero.org",
            "group_id": "2519759",
            "style": "digital-humanities-im-deutschsprachigen-raum",
            "api_key": ""
        },
        "upload": {
            "enabled": true,
            "target": "workspace",
            "accept": ".xml, .tei, .odd, .docx, .md, .mei"
        },
        "register": {
            "config": {
                "$replace": true,
                "place": {
                    "collection": "places"
                },
                "person": {
                    "collection": "people"
                }
            }
        }
    }
}
