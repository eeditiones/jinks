{
    "$schema": "../../schema/jinks.json",
    "type": "feature",
    "category": "components",
    "id": "https://e-editiones.org/app/tei-publisher/registers",
    "label": "Entity Registers",
    "shortname": "register",
    "description": "Adds pages to browse entities, i.e. people, places",
    "version": "1.0.0",
    "depends": [
        "base10"
    ],
    "order": 11,
    
    "templating": {
        "use": [
            "templates/register-blocks.html"
        ]
    },
    "features": {
        "register": {
            "enabled": false,
            "description": "auto"
        }
    },
    "menu": {
        "items": [
            {
                "id": "people",
                "url": "people"
            },
            {
                "id": "places",
                "url": "places"
            }
        ]
    },
    "api": [
        {
            "spec": "registers-api.json",
            "prefix": "rview",
            "path": "registers-api.xql",
            "id": "http://teipublisher.com/api/registers/view"
        }
    ],
    "i18n": [
        "registers"
    ],
    "theme": {
        "registers": {
            "columns": 2
        }
    },
    "defaults": {
        "register-map": { 
        "person": {
            "id": "pb-persons",
            "default": "person-default",
            "prefix": "person-"
        },
        "place":  {
            "id": "pb-places",
            "default": "place-default",
            "prefix": "place-"
        },
        "bibliography":  {
            "id": "pb-bibl",
            "default": "bibl-default",
            "prefix": "bibl-"
        },
        "organization":  {
            "id": "pb-organizations",
            "default": "organization-default",
            "prefix": "org-"
        },
        "term":  {
            "id": "pb-keywords",
            "default": "term-default",
            "prefix": "category-"
        },
        "work":  {
            "id": "pb-works",
            "default": "work-default",
            "prefix": "work-"
        }
    }}
}
