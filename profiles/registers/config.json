{
    "$schema": "../../schema/jinks.json",
    "type": "feature",
    "category": "components",
    "id": "https://e-editiones.org/app/tei-publisher/registers",
    "label": "Entity Registers",
    "shortname": "register",
    "description": "Adds pages to browse entities, i.e. people, places",
    "version": "1.0.0",
    "depends": [
        "base10"
    ],
    "order": 11,
    
    "templating": {
        "use": [
            "templates/register-blocks.html"
        ]
    },
    "features": {
        "register": {
            "enabled": false,
            "description": "auto",
            "config": {
                "person": {
                    "collection": "registers",
                    "id": "pb-persons"
                },
                "place": {
                    "collection": "registers",
                    "id": "pb-places"
                },
                "bibliography": {
                    "collection": "registers",
                    "id": "pb-bibl"
                },
                "organization": {
                    "collection": "registers",
                    "id": "pb-organizations"
                },
                "term": {
                    "collection": "registers",
                    "id": "pb-keywords"
                },
                "work": {
                    "collection": "registers",
                    "id": "pb-works"
                }
            }
        }
    },
    "menu": {
        "items": [
            {
                "id": "people",
                "url": "people"
            },
            {
                "id": "places",
                "url": "places"
            }
        ]
    },
    "api": [
        {
            "spec": "registers-api.json",
            "prefix": "rview",
            "path": "registers-api.xql",
            "id": "http://teipublisher.com/api/registers/view"
        }
    ],
    "i18n": [
        "registers"
    ],
    "theme": {
        "registers": {
            "columns": 2
        }
    }
}
